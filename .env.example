# Local configuration template.
# Copy this file to .env and fill in local-only values.
# Never commit .env.

# Optional Neo4j graph store:
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# Optional LLM agent provider.
# Default local Ollama/OpenAI-compatible setup:
OSINT_LLM_PROVIDER=openai_compatible
OSINT_LLM_BASE_URL=http://localhost:11434/v1
OSINT_LLM_MODEL=qwen2.5:3b
OSINT_LLM_API_KEY=
OSINT_LLM_TIMEOUT=300

# Optional hosted/future connector credentials:
# SHODAN_API_KEY=
# CENSYS_API_ID=
# CENSYS_API_SECRET=
